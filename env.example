# Copie este arquivo para .env.local e preencha com os valores do seu banco PostgreSQL
# URL de conexão com o PostgreSQL
DATABASE_URL=postgresql://usuario:senha@localhost:5432/nome_do_banco

# JWT Secret para autenticação
JWT_SECRET=sua_chave_secreta_super_segura_aqui_william_disk_pizza_2024

# Configuração do ambiente
NODE_ENV=development
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Logs de debug
ENABLE_QUERY_LOGS=true
ENABLE_SLOW_QUERY_LOGS=true
SLOW_QUERY_THRESHOLD=1000

# Mercado Pago Configuration
MERCADOPAGO_ACCESS_TOKEN=seu_access_token_aqui
MERCADOPAGO_PUBLIC_KEY=sua_public_key_aqui
MERCADOPAGO_WEBHOOK_SECRET=sua_webhook_secret_aqui

# Socket.io Configuration
SOCKET_IO_SECRET=sua_socket_secret_aqui

# Exemplo de URL para VPS (ajuste conforme sua configuração)
# DATABASE_URL=postgresql://williamdiskpizza:sua_senha@seu_servidor:5432/williamdiskpizza 