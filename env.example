# Copie este arquivo para .env.local e preencha com os valores do seu projeto Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Senha do banco Supabase (obtenha no painel administrativo do Supabase)
SUPABASE_DB_PASSWORD=postgres

# JWT Secret para autenticação
JWT_SECRET=sua_chave_secreta_super_segura_aqui_william_disk_pizza_2024

# Configuração do ambiente
NODE_ENV=development
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Logs de debug
ENABLE_QUERY_LOGS=true
ENABLE_SLOW_QUERY_LOGS=true
SLOW_QUERY_THRESHOLD=1000

