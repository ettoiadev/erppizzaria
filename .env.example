# =============================================================================
# VARIÁVEIS DE AMBIENTE - ERP PIZZARIA
# =============================================================================
# Este arquivo contém todas as variáveis de ambiente necessárias para o projeto.
# Copie este arquivo para .env.local e configure os valores apropriados.
#
# IMPORTANTE: 
# - Variáveis com NEXT_PUBLIC_ são expostas ao frontend
# - Variáveis sem prefixo são apenas para servidor (API Routes/Server Components)
# - NUNCA exponha chaves sensíveis ao frontend
# =============================================================================

# -----------------------------------------------------------------------------
# SUPABASE - BANCO DE DADOS
# -----------------------------------------------------------------------------
# URL do projeto Supabase (servidor apenas)
SUPABASE_URL=http://localhost:54321

# Chave do Supabase - Use anon key para desenvolvimento, service role para produção
# DESENVOLVIMENTO: Use anon key (eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...)
# PRODUÇÃO: Use service role key para máxima funcionalidade
SUPABASE_KEY=your-anon-or-service-role-key

# -----------------------------------------------------------------------------
# AUTENTICAÇÃO JWT
# -----------------------------------------------------------------------------
# Chave secreta para assinatura de tokens JWT (NUNCA exponha ao frontend)
# Gere uma chave forte: openssl rand -base64 32
JWT_SECRET=sua_chave_secreta_super_segura_aqui_min_32_chars

# -----------------------------------------------------------------------------
# MERCADO PAGO - PAGAMENTOS
# -----------------------------------------------------------------------------
# Token de acesso do Mercado Pago (servidor apenas)
# DESENVOLVIMENTO: Use TEST-xxxx
# PRODUÇÃO: Use APP_USR-xxxx
MERCADOPAGO_ACCESS_TOKEN=TEST-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Chave secreta para validação de webhooks (servidor apenas)
MERCADOPAGO_WEBHOOK_SECRET=your_webhook_secret_here

# -----------------------------------------------------------------------------
# CONFIGURAÇÕES PÚBLICAS (Expostas ao Frontend)
# -----------------------------------------------------------------------------
# URL base da aplicação (necessária para redirects e webhooks)
# DESENVOLVIMENTO: http://localhost:3000
# PRODUÇÃO: https://seu-dominio.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# CONFIGURAÇÕES DE DESENVOLVIMENTO
# -----------------------------------------------------------------------------
# Ambiente de execução
NODE_ENV=development

# Logs de consultas SQL (apenas desenvolvimento)
ENABLE_QUERY_LOGS=true
ENABLE_SLOW_QUERY_LOGS=true
SLOW_QUERY_THRESHOLD=1000

# Sistema de logging avançado
ENABLE_CONSOLE_LOGS=true
ENABLE_DETAILED_LOGS=false
ENABLE_ERROR_REPORTING=false
LOG_LEVEL=info
MAX_LOG_LENGTH=2000

# Configurações específicas do Supabase
ENABLE_QUERY_LOGS=false
ENABLE_SLOW_QUERY_LOGS=true
SLOW_QUERY_THRESHOLD=2000

# Configurações de Rate Limiting para Logs
ENABLE_LOG_RATE_LIMITING=true
MAX_LOGS_PER_MINUTE=100

# Configurações de Retenção de Logs
MAX_RECENT_ERRORS=20
MAX_LOG_HISTORY=100
LOG_CLEANUP_INTERVAL=600000

# -----------------------------------------------------------------------------
# CONFIGURAÇÕES OPCIONAIS
# -----------------------------------------------------------------------------
# Rate limiting (requisições por minuto)
RATE_LIMIT_REQUESTS=100

# Timeout para consultas (em ms)
DATABASE_TIMEOUT=30000

# -----------------------------------------------------------------------------
# VARIÁVEIS LEGADAS (NÃO USAR)
# -----------------------------------------------------------------------------
# As seguintes variáveis são legadas e não devem ser utilizadas:
# NEXT_PUBLIC_SUPABASE_URL - Use SUPABASE_URL
# NEXT_PUBLIC_SUPABASE_ANON_KEY - Use SUPABASE_KEY  
# SUPABASE_SERVICE_ROLE_KEY - Use SUPABASE_KEY