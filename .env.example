# =============================================================================
# CONFIGURAÇÕES DE AMBIENTE - ERP PIZZARIA
# =============================================================================
# IMPORTANTE: Copie este arquivo para .env.local e configure os valores reais
# NUNCA commite o arquivo .env.local com valores reais!

# =============================================================================
# SUPABASE - OBRIGATÓRIO
# =============================================================================
# URL do projeto Supabase
SUPABASE_URL=https://zrkxsetbsyecbatqbojr.supabase.co

# Chave pública do Supabase (anon key)
SUPABASE_KEY=sua_chave_publica_aqui

# Chave de serviço do Supabase (service role) - APENAS BACKEND
SUPABASE_SERVICE_ROLE_KEY=sua_chave_service_role_aqui

# =============================================================================
# AUTENTICAÇÃO - OBRIGATÓRIO
# =============================================================================
# Chave secreta para JWT (mínimo 32 caracteres)
JWT_SECRET=sua_chave_jwt_super_segura_de_pelo_menos_32_caracteres

# Chave secreta para refresh tokens (mínimo 32 caracteres)
REFRESH_TOKEN_SECRET=sua_chave_refresh_super_segura_de_32_caracteres

# =============================================================================
# APLICAÇÃO - OBRIGATÓRIO
# =============================================================================
# URL base da aplicação
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Ambiente de execução
NODE_ENV=development

# =============================================================================
# MERCADO PAGO - OPCIONAL
# =============================================================================
# Token de acesso do Mercado Pago
MERCADOPAGO_ACCESS_TOKEN=TEST-sua_chave_de_teste_aqui

# Chave pública do Mercado Pago
NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY=TEST-sua_chave_publica_aqui

# Secret para webhooks do Mercado Pago
MERCADOPAGO_WEBHOOK_SECRET=sua_chave_webhook_secreta_aqui

# =============================================================================
# LOGGING E DEBUGGING - OPCIONAL
# =============================================================================
# Habilitar logs de queries
ENABLE_QUERY_LOGS=true

# Habilitar logs de queries lentas
ENABLE_SLOW_QUERY_LOGS=true

# Threshold para queries lentas (ms)
SLOW_QUERY_THRESHOLD=1000

# Habilitar logs no console
ENABLE_CONSOLE_LOGS=true

# Habilitar logs detalhados
ENABLE_DETAILED_LOGS=true

# Nível de log (error, warn, info, debug)
LOG_LEVEL=info

# Tamanho máximo dos logs
MAX_LOG_LENGTH=1000

# Habilitar relatórios de erro
ENABLE_ERROR_REPORTING=true

# =============================================================================
# SENTRY - OPCIONAL
# =============================================================================
# DSN do Sentry para monitoramento de erros
SENTRY_DSN=sua_dsn_do_sentry_aqui

# Organização do Sentry
SENTRY_ORG=sua_organizacao_sentry

# Projeto do Sentry
SENTRY_PROJECT=seu_projeto_sentry

# =============================================================================
# SERVIDOR - OPCIONAL
# =============================================================================
# Porta do servidor (padrão: 3000)
PORT=3000