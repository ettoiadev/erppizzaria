# Variáveis de ambiente para produção
# Estas serão sobrescritas pelas configurações da Vercel

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key-here
JWT_SECRET=your-production-jwt-secret
NEXT_PUBLIC_SITE_URL=https://your-domain.vercel.app
MERCADOPAGO_ACCESS_TOKEN=PROD-your-production-token
MERCADOPAGO_WEBHOOK_SECRET=your-production-webhook-secret

# Logs
ENABLE_QUERY_LOGS=false
ENABLE_SLOW_QUERY_LOGS=false
SLOW_QUERY_THRESHOLD=2000